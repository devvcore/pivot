# ── Required ──────────────────────────────────────────────────────────────────

# GEMINI_API_KEY: Required for all AI features (synthesis, agents, coaching, voice call).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key"

# ── Optional ─────────────────────────────────────────────────────────────────

# PERPLEXITY_API_KEY: Enables web research during onboarding (industry, current events).
# Get a key at https://www.perplexity.ai/settings/api
# PERPLEXITY_API_KEY="pplx-..."

# NYNE_API_KEY / NYNE_API_SECRET: Enables lead generation feature.
# NYNE_API_KEY=""
# NYNE_API_SECRET=""

# TWOSLIDES_API_KEY: Enables pitch deck generation via 2slides.com.
# TWOSLIDES_API_KEY="sk-2slides-..."

# APP_URL: The public URL where this app is hosted (used for share links).
# APP_URL="https://yourdomain.com"

# ── Pipeline Tuning (advanced) ───────────────────────────────────────────────

# MICRO_AGENT_MODEL: Model for micro-agents in ingest pipeline (default: gemini-3-flash-preview)
# MICRO_AGENT_MODEL="gemini-3-flash-preview"

# ORCHESTRATOR_MODEL: Model for orchestrator in ingest pipeline (default: gemini-3-flash-preview)
# ORCHESTRATOR_MODEL="gemini-3-flash-preview"

# MICRO_AGENT_PARALLELISM: Number of parallel micro-agents (default: 4)
# MICRO_AGENT_PARALLELISM="4"
